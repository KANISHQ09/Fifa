# -----------------------------------------------------------------------------
# StadiumPulse AI - Production Environment Configuration Template
# Copy this file to '.env' and adjust variables for your deployment.
# -----------------------------------------------------------------------------

# AI Concierge & Translation Configuration
# Optional: Provide a Gemini API key to connect live RAG models instead of simulated pipelines
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Operations & Simulation Settings
# The tick rate for simulated crowd movements, energy grids, and volunteer travel (in milliseconds)
VITE_SIMULATION_INTERVAL_MS=5000

# Crowd Surge & Navigation Congestion Threshold
# Defines the zone capacity percentage (0-100) above which security gates are flagged as congested and auto-rerouted
VITE_CROWD_CONGESTION_THRESHOLD=75

# Analytics & Exporters
# Enables live CSV audits and formatted text report compiles
VITE_ENABLE_REPORTS_EXPORT=true
